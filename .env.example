# Solanka Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=Solanka
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-here-change-this

# Auth (JWT)
JWT_SECRET_KEY=your-jwt-secret-change-in-prod
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite+aiosqlite:///./solanka.db

# Solana
HELIUS_API_KEY=your-helius-api-key-here
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your-helius-api-key-here
MERCHANT_WALLET_ADDRESS=your-solana-wallet-address-here

# Exchange Rate
BINANCE_API_URL=https://api.binance.com/api/v3/ticker/price

# App base URL (used in payment link responses)
APP_BASE_URL=https://solanka-production.up.railway.app

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Google OAuth
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://solanka-production.up.railway.app/api/v1/auth/google/callback

# Frontend URL (used for OAuth redirect after callback)
FRONTEND_URL=http://localhost:3000

# KYC Tier 1 — Dojah (Nigerian BVN/NIN verification)
# Sign up free at https://dojah.io
DOJAH_APP_ID=your-dojah-app-id
DOJAH_SECRET_KEY=your-dojah-secret-key
KYC_SANDBOX=true   # set false in production

# KYC Tier 2 — Onfido (document + selfie liveness)
# Sign up at https://onfido.com (free sandbox)
ONFIDO_API_TOKEN=api_sandbox.your-token-here
ONFIDO_REGION=EU   # EU | US | CA
ONFIDO_WEBHOOK_TOKEN=your-onfido-webhook-token

# Email — Resend (3,000 free emails/month)
# Sign up at https://resend.com
RESEND_API_KEY=re_your-api-key-here
EMAIL_FROM=Solanka <noreply@solanka.io>

# Helius Webhooks (real-time payment notifications)
# Register webhook at https://dev.helius.xyz/webhooks/app
# Webhook type: Enhanced Transactions | Filter: TOKEN_TRANSFER
HELIUS_WEBHOOK_SECRET=your-helius-webhook-secret
